<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About | GIIS Robotics Club</title>
    <link rel="icon" type="image/x-icon" href="resources/favicon.ico">
    <style>
        @font-face {
            font-family: 'crest';
            src: url('/crst.otf') format('opentype');
        }
        @font-face {
            font-family: 'crestb';
            src: url('/crstb.otf') format('opentype');
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html, body{
            width: 100%;
            min-height: 100vh;
            margin: 0;
            background-color: #111111;
            color: #ffffff;
            font-family: 'crest';
            background-image: url('/logo/background.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
        
        nav{
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            background: linear-gradient(180deg, rgba(20, 33, 61, 0.8) 51%, rgba(30, 30, 47, 0.8) 100%);
            border-radius: 0 0 20px 20px;
            box-shadow: 0 8px 22px rgba(0,0,0,0.4);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
        }
        
        .nav-brand span {
            font-size: 14px;
            opacity: 0.9;
        }
        
        .nav-links {
            display: flex;
            list-style: none;
            gap: 25px;
            margin: 0;
            padding: 0;
        }
        
        .nav-links a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 14px;
            padding: 8px 15px;
            border-radius: 20px;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        .nav-links a:hover, .nav-links a.active {
            background: rgba(108, 99, 255, 0.2);
            color: #ffffff;
        }
        
        .login-link {
            color: #ffffff;
            text-decoration: none;
            font-size: 14px;
            padding: 10px 20px;
            border-radius: 25px;
            background: linear-gradient(135deg, #6c63ff, #4a47a3);
            transition: all 0.3s ease;
            font-weight: 600;
        }
        
        .login-link:hover {
            background: linear-gradient(135deg, #5a52d5, #3e3b8a);
            transform: translateY(-1px);
        }

        .main-content {
            padding: 120px 24px 80px;
        }

        .about-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 54px;
        }

        .hero {
            display: flex;
            flex-direction: column;
            gap: 16px;
            text-align: center;
        }

        .hero h1 {
            font-size: clamp(2.4rem, 5vw, 3.6rem);
            margin: 0;
            letter-spacing: 1.6px;
            font-family: 'crestb';
        }

        .hero p {
            margin: 0 auto;
            max-width: 720px;
            font-size: clamp(1.05rem, 2.6vw, 1.35rem);
            line-height: 1.7;
            color: rgba(255,255,255,0.78);
        }

        .team-sections {
            display: flex;
            flex-direction: column;
            gap: 46px;
        }

        .team-section {
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .section-header::before {
            content: "";
            width: 40px;
            height: 3px;
            border-radius: 999px;
            background: linear-gradient(90deg, rgba(108,99,255,0.85), rgba(74,71,163,0.85));
        }

        .section-header h2 {
            margin: 0;
            font-size: clamp(1.6rem, 3.2vw, 2.2rem);
            letter-spacing: 1px;
        }

        .member-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 36px;
        }

        .member-card {
            background: linear-gradient(135deg, rgba(35,35,55,0.75), rgba(25,18,40,0.75));
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 22px;
            padding: 32px 26px 34px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 22px;
            text-align: center;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.6), 0 8px 16px rgba(0,0,0,0.4);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .member-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 85% 15%, rgba(108,99,255,0.15), transparent 60%);
            pointer-events: none;
            opacity: 0.8;
        }
        
        .member-card > * {
            position: relative;
            z-index: 1;
        }
        
        .member-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 35px 70px -15px rgba(0,0,0,0.7), 0 12px 20px rgba(0,0,0,0.5);
        }

        .team-photo-wrapper {
            width: 220px;
            height: 220px;
            border-radius: 50%;
            overflow: hidden;
            position: relative;
            background: linear-gradient(135deg, rgba(108,99,255,0.8), rgba(74,71,163,0.85));
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .team-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .team-photo.hidden {
            display: none;
        }

        .photo-fallback {
            position: absolute;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 2.4rem;
            font-weight: 600;
            color: rgba(255,255,255,0.92);
            letter-spacing: 1px;
        }

        .photo-fallback.visible {
            display: flex;
        }

        .member-info h3 {
            margin: 0;
            font-size: clamp(1.4rem, 3vw, 1.8rem);
            letter-spacing: 0.6px;
        }

        .member-info span {
            display: block;
            margin-top: 6px;
            font-size: 1rem;
            letter-spacing: 0.5px;
            color: rgba(255,255,255,0.65);
        }

        .footer-note {
            text-align: center;
            font-size: 1rem;
            color: rgba(255,255,255,0.65);
            letter-spacing: 0.5px;
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }
            
            .login-link {
                font-size: 12px;
                padding: 8px 16px;
            }
            
            .main-content {
                padding: 100px 20px 50px;
            }
            
            .member-gallery {
                grid-template-columns: 1fr;
                gap: 24px;
            }
            
            .team-photo-wrapper {
                width: 200px;
                height: 200px;
            }
        }

        @media (max-width: 520px) {
            .section-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .section-header::before {
                width: 80px;
            }

            .member-gallery {
                gap: 28px;
            }

            .member-card {
                padding: 28px 24px;
            }

            .team-photo-wrapper {
                width: 180px;
                height: 180px;
            }
            
            .main-content {
                padding: 90px 15px 40px;
            }
            
            .nav-brand span {
                font-size: 12px;
            }
        }
    </style>
</head>
